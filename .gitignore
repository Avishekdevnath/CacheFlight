# -----------------------------
# CacheFlight ignore rules
# -----------------------------

# Hide planning/docs guide folder
guide/

# Ignore all Markdown files by default
*.md
**/*.md

# Keep README files tracked
!README.md
!**/README.md

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging/build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test/cache/tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# OS/editor junk
.DS_Store
Thumbs.db
.vscode/
.claude/
